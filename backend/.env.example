PORT=4000
NODE_ENV=development
FRONTEND_ORIGIN=http://localhost:3000

MONGODB_URI=mongodb://127.0.0.1:27017/soroban-stream

# Fine-grained GitHub PAT needs Issues: Read and write for the target repo.
GITHUB_TOKEN=github_pat_your_token_here
GITHUB_OWNER=your-github-org-or-username
GITHUB_REPO=soroban-stream
